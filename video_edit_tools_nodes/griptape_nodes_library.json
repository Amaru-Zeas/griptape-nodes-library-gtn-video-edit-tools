        ],
        "dependencies": {
            "pip_dependencies": [
                "imageio[ffmpeg]>=2.37.0",
                "numpy>=1.26.0",
                "color-matcher"
            ]
        }
    },
    "settings": [],
    "categories": [
        {
            "VideoTools": {
                "color": "border-cyan-500",
